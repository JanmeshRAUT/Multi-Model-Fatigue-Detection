# ==========================================
# Frontend Environment Configuration
# ==========================================

# Backend API URL
# For HF Space Backend (production):
REACT_APP_API_URL=https://your-username-fatigue-backend.hf.space

# For local development with tunnel:
# REACT_APP_API_URL=https://abc-123-xyz.ngrok.io

# Build settings
GENERATE_SOURCEMAPS=false
SKIP_PREFLIGHT_CHECK=true
NODE_OPTIONS=--max_old_space_size=4096
DISABLE_SOURCEMAP_WARNINGS=true

# Optional: API configuration
REACT_APP_API_TIMEOUT=30000
REACT_APP_DEBUG=false


