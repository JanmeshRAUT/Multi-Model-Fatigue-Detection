# Arduino Bridge Configuration
# Copy this to .env in the root directory

# Arduino Connection Settings
ARDUINO_PORT=COM6
BAUD_RATE=115200

# Flask Server Settings
FLASK_PORT=5000
FLASK_HOST=0.0.0.0
FLASK_DEBUG=False

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Remote backend URL (for testing)
# REMOTE_BACKEND_URL=https://your-username-fatigue-backend.hf.space
