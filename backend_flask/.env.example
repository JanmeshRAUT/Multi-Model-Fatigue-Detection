# ==========================================
# Hugging Face Model Configuration
# ==========================================
# Set your Hugging Face model repositories here
HF_FATIGUE_MODEL_REPO=your-username/fatigue-model
HF_VEHICLE_MODEL_REPO=your-username/vehicle-model

# Optional: HF Token for private repositories
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=

# ==========================================
# Hugging Face Inference API (Optional)
# ==========================================
# Use HF Inference API for predictions (primary)
# Falls back to local models if API unavailable
USE_HF_INFERENCE_API=True

# Your HF API token (can be same as HF_TOKEN above)
HF_API_TOKEN=

# ==========================================
# Arduino/Serial Configuration
# ==========================================
ARDUINO_PORT=COM6
BAUD_RATE=115200

# ==========================================
# Backend Configuration
# ==========================================
DEBUG=True
USE_MOCK_DATA=False
ML_INTERVAL=0.5
MAX_HISTORY=100
SENSOR_TIMEOUT=2.0
